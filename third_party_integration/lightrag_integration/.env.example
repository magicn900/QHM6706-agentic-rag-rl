# ==============================
# LightRAG integration env sample
# ==============================

# Preferred conda env
# agentic-rl

# --- Provider endpoint configuration ---
# Option A (recommended for third-party OpenAI-compatible providers):
# Use one shared endpoint + one shared key
LIGHTRAG_BASE_URL=
LIGHTRAG_API_KEY=

# Option B (if LLM/Embedding use different endpoints/keys):
LIGHTRAG_LLM_BASE_URL=
LIGHTRAG_LLM_API_KEY=
LIGHTRAG_EMBED_BASE_URL=
LIGHTRAG_EMBED_API_KEY=

# --- Model configuration ---
# Example values:
# - OpenAI: gpt-4o-mini / text-embedding-3-small
# - Third-party compatible: vendor-specific model IDs
LIGHTRAG_LLM_MODEL=gpt-4o-mini
LIGHTRAG_EMBED_MODEL=text-embedding-3-small
LIGHTRAG_EMBED_DIM=1536
LIGHTRAG_EMBED_MAX_TOKENS=8192

# --- Optional rerank configuration ---
# Supported providers: cohere | jina | ali
LIGHTRAG_RERANK_PROVIDER=
LIGHTRAG_RERANK_MODEL=
LIGHTRAG_RERANK_TOP_N=10

# Provider keys (if rerank is enabled)
COHERE_API_KEY=
JINA_API_KEY=
DASHSCOPE_API_KEY=
RERANK_BINDING_API_KEY=
