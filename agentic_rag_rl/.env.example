# ==================================
# Core Agentic-RAG API env template
# Preferred location: agentic_rag_rl/.env
# ==================================

# --- Provider endpoint configuration ---
# Option A: one shared endpoint + one shared key
AGENTIC_RAG_LLM_BASE_URL=
AGENTIC_RAG_LLM_API_KEY=

# Option B: split embed endpoint/key if different
AGENTIC_RAG_EMBED_BASE_URL=
AGENTIC_RAG_EMBED_API_KEY=

# --- Model configuration ---
AGENTIC_RAG_LLM_MODEL=gpt-4o-mini
AGENTIC_RAG_EMBED_MODEL=text-embedding-3-small
AGENTIC_RAG_EMBED_DIM=1536

# --- Action policy model (optional override) ---
AGENTIC_RAG_ACTION_BASE_URL=
AGENTIC_RAG_ACTION_API_KEY=
AGENTIC_RAG_ACTION_MODEL=gpt-4o-mini

# Backward compatibility:
# If AGENTIC_RAG_* is not set, code will fallback to LIGHTRAG_* vars.
